# Backend API (used by Next.js rewrites in next.config.ts)
API_INTERNAL_URL=http://your-api-server:8080

# Public URLs (baked in at build time for NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_URL=https://your-ui-domain.com
NEXT_PUBLIC_USER_APP_URL=https://your-ui-domain.com
NEXT_PUBLIC_ADMIN_APP_URL=https://your-admin-domain.com
