# Backend API (used by Next.js rewrites in next.config.ts)
API_INTERNAL_URL=http://your-api-server:8080

# Public URLs (baked in at build time for NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_URL=https://your-ui-domain.com
NEXT_PUBLIC_USER_APP_URL=https://your-ui-domain.com
NEXT_PUBLIC_ADMIN_APP_URL=https://your-admin-domain.com

# Site feature flags are controlled in admin → Site controls (runtime via API).
# NEXT_PUBLIC_PLANS_SELL_ENABLED is no longer used for customer UI behavior.

# Public Telegram / support (optional overrides; defaults in web/src/lib/site.ts)
NEXT_PUBLIC_SUPPORT_CONTACT=@takvpnsupportt
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/takvpnofficial
NEXT_PUBLIC_TELEGRAM_SUPPORT_URL=https://t.me/takvpnsupportt
